{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "steel.run-complete.v1",
  "title": "Steel Run Complete",
  "description": "Signal from GeminiClaw to orchestrator when producer work is done.",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "owner_runtime",
    "project_name",
    "status",
    "delivery_mode",
    "handoff_path",
    "source_inventory_path",
    "download_manifest_path",
    "workbooks_validated",
    "outputs",
    "created_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "const": "steel.run-complete.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_runtime": {
      "type": "string",
      "enum": ["geminiclaw"]
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["complete", "failed"]
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["standard", "procurement-grade"]
    },
    "handoff_path": {
      "type": "string",
      "minLength": 1
    },
    "source_inventory_path": {
      "type": "string",
      "minLength": 1
    },
    "download_manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "workbooks_validated": {
      "type": "boolean"
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "path", "md5"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["workbook", "pdf", "source", "report"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "md5": {
            "type": "string",
            "pattern": "^[a-f0-9]{32}$"
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "not": {
    "anyOf": [
      { "required": ["targetDir"] },
      { "required": ["credentials_path"] }
    ]
  }
}
