{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "steel.run-complete.v1",
  "title": "Steel Run Complete",
  "description": "Signal from GeminiClaw to orchestrator when producer work is done.",
  "type": "object",
  "required": [
    "schema",
    "run_id",
    "owner_runtime",
    "project_name",
    "status",
    "delivery_mode",
    "handoff_path",
    "source_inventory_path",
    "download_manifest_path",
    "workbooks_validated",
    "outputs",
    "created_at"
  ],
  "additionalProperties": true,
  "properties": {
    "schema": {
      "type": "string",
      "const": "steel.run-complete.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "owner_runtime": {
      "type": "string",
      "enum": ["geminiclaw"]
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "project_no": {
      "type": "string"
    },
    "project": {
      "type": "string",
      "description": "Alias for project_name for workbook-generator"
    },
    "status": {
      "type": "string",
      "enum": ["complete", "failed"]
    },
    "delivery_mode": {
      "type": "string",
      "enum": ["standard", "procurement-grade"]
    },
    "handoff_path": {
      "type": "string",
      "minLength": 1
    },
    "source_inventory_path": {
      "type": "string",
      "minLength": 1
    },
    "download_manifest_path": {
      "type": "string",
      "minLength": 1
    },
    "workbooks_validated": {
      "type": "boolean"
    },
    "subprojects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "totals", "profiles"],
        "properties": {
          "name": { "type": "string" },
          "coating": { "type": "string" },
          "coating_summary": { "type": "string" },
          "fire_summary": { "type": "string" },
          "transport_summary": { "type": "string" },
          "exec_class": { "type": "string" },
          "fire_protection": { "type": "string" },
          "welding": { "type": "string" },
          "gratings_steps": { "type": "string" },
          "notes": { "type": "string" },
          "source_total_kg": { "type": "number" },
          "categories": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "weight_kg", "paint_m2", "qty"],
              "properties": {
                "name": { "type": "string" },
                "coating": { "type": "string" },
                "coating_class": { "type": "string" },
                "fire_class": { "type": "string" },
                "exec_class": { "type": "string" },
                "notes": { "type": "string" },
                "weight_kg": { "type": "number" },
                "paint_m2": { "type": "number" },
                "qty": { "type": "number" },
                "length_m": { "type": "number" }
              }
            }
          },
          "profiles": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["profile", "steel_grade", "qty", "length_m", "weight_kg", "paint_m2"],
              "properties": {
                "profile": { "type": "string" },
                "category": { "type": "string" },
                "fire_class": { "type": "string" },
                "critical_temp_c": { "type": ["number", "null"] },
                "am_v": { "type": ["number", "null"] },
                "coating": { "type": "string" },
                "source": { "type": "string" },
                "steel_grade": { "type": "string" },
                "standard": { "type": ["string", "null"] },
                "qty": { "type": "number" },
                "length_m": { "type": "number" },
                "weight_kg": { "type": "number" },
                "paint_m2": { "type": "number" }
              }
            }
          },
          "source_rows": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["part", "profile", "steel_grade", "qty", "length_mm", "weight_kg", "paint_m2"],
              "properties": {
                "part": { "type": "string" },
                "part_no": { "type": "string" },
                "assembly_no": { "type": "string" },
                "profile": { "type": "string" },
                "steel_grade": { "type": "string" },
                "standard": { "type": ["string", "null"] },
                "qty": { "type": "number" },
                "length_mm": { "type": "number" },
                "weight_kg": { "type": "number" },
                "paint_m2": { "type": "number" },
                "source_line": { "type": "string" },
                "category": { "type": "string" },
                "am": { "type": "number" },
                "coating": { "type": "string" },
                "fire_class": { "type": "string" },
                "critical_temp_c": { "type": ["number", "null"] },
                "oversize": { "type": "string" },
                "area_weight_source": { "type": "string" },
                "source": { "type": "string" }
              }
            }
          },
          "assembly_map": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["assembly_no", "part_no", "profile", "steel_grade", "qty", "length_mm", "weight_kg", "paint_m2"],
              "properties": {
                "assembly_no": { "type": "string" },
                "part_no": { "type": "string" },
                "profile": { "type": "string" },
                "steel_grade": { "type": "string" },
                "standard": { "type": ["string", "null"] },
                "qty": { "type": "number" },
                "length_mm": { "type": "number" },
                "weight_kg": { "type": "number" },
                "paint_m2": { "type": "number" },
                "category": { "type": "string" },
                "source": { "type": "string" },
                "source_line": { "type": "string" }
              }
            }
          },
          "oversize": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["part", "profile", "steel_grade", "qty", "length_mm", "weight_kg", "paint_m2"],
              "properties": {
                "part": { "type": "string" },
                "profile": { "type": "string" },
                "steel_grade": { "type": "string" },
                "qty": { "type": "number" },
                "length_mm": { "type": "number" },
                "weight_kg": { "type": "number" },
                "paint_m2": { "type": "number" },
                "area_weight_source": { "type": "string" },
                "category": { "type": "string" },
                "source": { "type": "string" },
                "source_line": { "type": "string" }
              }
            }
          },
          "excluded_rows": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "subproject": { "type": "string" },
                "category": { "type": "string" },
                "assembly_no": { "type": "string" },
                "part": { "type": "string" },
                "part_no": { "type": "string" },
                "profile": { "type": "string" },
                "steel_grade": { "type": "string" },
                "qty": { "type": "number" },
                "length_mm": { "type": "number" },
                "weight_kg": { "type": "number" },
                "paint_m2": { "type": "number" },
                "am": { "type": "number" },
                "coating": { "type": "string" },
                "fire_class": { "type": "string" },
                "critical_temp_c": { "type": ["number", "null"] },
                "oversize": { "type": "string" },
                "exclusion_reason": { "type": "string" },
                "source": { "type": "string" }
              }
            }
          },
          "totals": {
            "type": "object",
            "required": ["weight_kg", "paint_m2"],
            "properties": {
              "weight_kg": { "type": "number" },
              "paint_m2": { "type": "number" }
            }
          }
        }
      }
    },
    "excluded": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["subproject", "scope", "reason", "weight_kg", "paint_m2"],
        "properties": {
          "subproject": { "type": "string" },
          "scope": { "type": "string" },
          "reason": { "type": "string" },
          "weight_kg": { "type": "number" },
          "paint_m2": { "type": "number" },
          "assembly_weight_kg": { "type": "number" },
          "assembly_paint_m2": { "type": "number" }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "properties": {
              "subproject": { "type": "string" },
              "source_type": { "type": "string" },
              "type": { "type": "string" },
              "file_name": { "type": "string" },
              "name": { "type": "string" },
              "used_for": { "type": "string" },
              "priority": { "type": "string" },
              "notes": { "type": "string" }
            }
          }
        ]
      }
    },
    "sources_detail": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "subproject": { "type": "string" },
          "source_type": { "type": "string" },
          "type": { "type": "string" },
          "file_name": { "type": "string" },
          "name": { "type": "string" },
          "used_for": { "type": "string" },
          "priority": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "transport_detail": {
      "type": "object",
      "properties": {
        "t1": { "type": "array", "items": { "type": "object" } },
        "t2": { "type": "array", "items": { "type": "object" } }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "analysis_warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "path", "md5"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["workbook", "pdf", "source", "report"]
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "md5": {
            "type": "string",
            "pattern": "^[a-f0-9]{32}$"
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "not": {
    "anyOf": [
      { "required": ["targetDir"] },
      { "required": ["credentials_path"] }
    ]
  }
}
